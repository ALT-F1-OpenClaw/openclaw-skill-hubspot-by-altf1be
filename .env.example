# HubSpot Skill Configuration
# Copy to .env and fill in your values

# ─── Authentication Mode 1: Private App Token (simple) ──────────────────────

# Private App access token from HubSpot Settings > Integrations > Private Apps
HUBSPOT_ACCESS_TOKEN=

# ─── Authentication Mode 2: OAuth 2.0 (advanced) ────────────────────────────
# If HUBSPOT_CLIENT_ID is set, OAuth mode is used instead of Private App token.

# OAuth App Client ID
# HUBSPOT_CLIENT_ID=

# OAuth App Client Secret
# HUBSPOT_CLIENT_SECRET=

# OAuth Refresh Token (obtained via OAuth flow)
# HUBSPOT_REFRESH_TOKEN=

# ─── Optional ────────────────────────────────────────────────────────────────

# Max results per query (default: 100)
# HUBSPOT_MAX_RESULTS=100
